<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>工作日志系统</title>
    <HTA:APPLICATION 
        APPLICATIONNAME="工作日志系统"
        VERSION="1.0"
        MAXIMIZEBUTTON="yes"
        MINIMIZEBUTTON="yes"
        SHOWINTASKBAR="yes"
        SINGLEINSTANCE="yes"
        WINDOWSTATE="normal"
        BORDER="thin"
        SCROLL="yes"
        INNERBORDER="no"
    >
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html-docx-js/0.3.1/html-docx.min.js"></script>
    <style>
        body { font-family: 'Microsoft YaHei', Arial, sans-serif; margin: 0; padding: 0; overflow: hidden; }
        .image-preview { max-width: 200px; max-height: 150px; object-fit: cover; border-radius: 8px; }
        .image-gallery { display: flex; flex-wrap: wrap; gap: 8px; }
        textarea { resize: vertical; }
        .doc-item:hover { background-color: #f3f4f6; }
    </style>
</head>
<body class="bg-gray-100">
    <div class="flex h-screen">
        <!-- 左侧日志列表 -->
        <div class="w-80 bg-white border-r border-gray-200 flex flex-col">
            <div class="p-4 border-b border-gray-200 bg-blue-600">
                <h1 class="text-xl font-bold text-white">📋 工作日志</h1>
            </div>
            
            <!-- 搜索框 -->
            <div class="p-3 border-b border-gray-200">
                <input type="text" id="searchInput" placeholder="搜索工作内容..." 
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            
            <!-- 新增按钮 -->
            <div class="p-3 border-b border-gray-200">
                <button onclick="createNewLog()" 
                    class="w-full bg-green-500 hover:bg-green-600 text-white font-bold py-2 px-4 rounded-lg transition">
                    ➕ 新增工作日志
                </button>
            </div>
            
            <!-- 导出文档管理按钮 -->
            <div class="p-3 border-b border-gray-200">
                <button onclick="openDocManager()" 
                    class="w-full bg-purple-500 hover:bg-purple-600 text-white font-bold py-2 px-4 rounded-lg transition">
                    📁 已导出文档
                </button>
            </div>
            
            <!-- 日志列表 -->
            <div id="logList" class="flex-1 overflow-y-auto">
            </div>
        </div>
        
        <!-- 右侧详情区域 -->
        <div class="flex-1 overflow-y-auto">
            <div id="detailArea" class="p-8">
                <div id="noSelection" class="text-center text-gray-400 mt-20">
                    <p class="text-6xl mb-4">📝</p>
                    <p class="text-xl">请从左侧选择一个日志查看详情</p>
                    <p class="text-sm mt-2">或点击"新增工作日志"创建新的记录</p>
                </div>
                
                <!-- 日志表单 -->
                <div id="logForm" class="hidden max-w-4xl mx-auto bg-white rounded-xl shadow-lg p-6">
                    <div class="flex justify-between items-center mb-6">
                        <h2 id="formTitle" class="text-2xl font-bold text-gray-800">新增工作日志</h2>
                        <div class="flex gap-2">
                            <button onclick="saveLog()" 
                                class="bg-blue-500 hover:bg-blue-600 text-white font-bold py-2 px-4 rounded-lg transition">
                                💾 保存
                            </button>
                            <button onclick="exportCurrentToWord()" id="exportCurrentBtn"
                                class="bg-green-500 hover:bg-green-600 text-white font-bold py-2 px-4 rounded-lg transition hidden">
                                📄 导出此条Word
                            </button>
                            <button onclick="deleteLog()" id="deleteBtn"
                                class="bg-red-500 hover:bg-red-600 text-white font-bold py-2 px-4 rounded-lg transition">
                                🗑️ 删除
                            </button>
                        </div>
                    </div>
                    
                    <div class="grid grid-cols-2 gap-4 mb-4">
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-1">📅 日期</label>
                            <input type="date" id="logDate" 
                                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
                        </div>
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-1">⏰ 时间</label>
                            <input type="time" id="logTime" 
                                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
                        </div>
                    </div>
                    
                    <div class="mb-4">
                        <label class="block text-sm font-bold text-gray-700 mb-1">📋 工作内容</label>
                        <textarea id="logContent" rows="3" 
                            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                            placeholder="描述本次工作的具体内容..."></textarea>
                    </div>
                    
                    <div class="grid grid-cols-2 gap-4 mb-4">
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-1">🔧 备件</label>
                            <textarea id="logSpareParts" rows="2" 
                                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                                placeholder="本次工作使用的备件列表..."></textarea>
                        </div>
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-1">🛠️ 工具</label>
                            <textarea id="logTools" rows="2" 
                                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                                placeholder="本次工作使用的工具..."></textarea>
                        </div>
                    </div>
                    
                    <div class="mb-4">
                        <label class="block text-sm font-bold text-gray-700 mb-1">⚠️ 注意事项</label>
                        <textarea id="logPrecautions" rows="2" 
                            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                            placeholder="工作安全注意事项..."></textarea>
                    </div>
                    
                    <div class="mb-4">
                        <label class="block text-sm font-bold text-gray-700 mb-1">📌 工作步骤</label>
                        <textarea id="logSteps" rows="4" 
                            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                            placeholder="按步骤描述工作流程..."></textarea>
                    </div>
                    
                    <!-- 图片上传 -->
                    <div class="mb-4">
                        <label class="block text-sm font-bold text-gray-700 mb-1">📷 工作图片</label>
                        <div class="border-2 border-dashed border-gray-300 rounded-lg p-4 text-center">
                            <input type="file" id="imageInput" accept="image/*" multiple 
                                class="hidden" onchange="handleImageUpload(event)">
                            <button onclick="document.getElementById('imageInput').click()"
                                class="bg-purple-500 hover:bg-purple-600 text-white font-bold py-2 px-4 rounded-lg transition">
                                📷 选择图片
                            </button>
                            <p class="text-sm text-gray-500 mt-2">支持 JPG、PNG、GIF 格式，可选择多张图片</p>
                        </div>
                        <div id="imagePreview" class="image-gallery mt-4">
                        </div>
                    </div>
                    
                    <div id="lastUpdated" class="text-sm text-gray-400 text-right mt-4 hidden">
                        最后更新: <span id="updatedTime"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- 删除确认弹窗 -->
    <div id="deleteModal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center hidden z-50">
        <div class="bg-white rounded-xl p-6 max-w-sm">
            <h3 class="text-lg font-bold text-gray-800 mb-2">确认删除</h3>
            <p class="text-gray-600 mb-4">确定要删除这条工作日志吗？此操作无法撤销。</p>
            <div class="flex justify-end gap-2">
                <button onclick="closeDeleteModal()" 
                    class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-100">取消</button>
                <button onclick="confirmDelete()" 
                    class="px-4 py-2 bg-red-500 text-white rounded-lg hover:bg-red-600">确认删除</button>
            </div>
        </div>
    </div>
    
    <!-- 文档管理弹窗 -->
    <div id="docManagerModal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center hidden z-50">
        <div class="bg-white rounded-xl p-6 max-w-4xl w-full mx-4 max-h-[80vh] flex flex-col">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-xl font-bold text-gray-800">📁 已导出的Word文档</h3>
                <button onclick="closeDocManager()" class="text-gray-500 hover:text-gray-700 text-2xl">&times;</button>
            </div>
            <div class="bg-gray-100 rounded-lg p-3 mb-4 flex justify-between items-center">
                <span class="text-gray-600">共 <span id="docCount" class="font-bold text-purple-600">0</span> 个文档</span>
            </div>
            <div class="mb-4">
                <input type="text" id="docSearchInput" placeholder="🔍 搜索文档内容..." 
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500"
                    oninput="renderDocList(this.value)">
            </div>
            <div id="docList" class="flex-1 overflow-y-auto">
                <div class="text-center text-gray-400 py-8">📭 暂无导出的文档</div>
            </div>
        </div>
    </div>
    
    <!-- 导出选项弹窗 -->
    <div id="exportOptionModal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center hidden z-50">
        <div class="bg-white rounded-xl p-6 max-w-sm">
            <h3 class="text-lg font-bold text-gray-800 mb-4">📄 导出选项</h3>
            <div class="flex flex-col gap-3">
                <button onclick="doExportWord(false)" 
                    class="w-full bg-blue-500 hover:bg-blue-600 text-white font-bold py-3 px-4 rounded-lg transition">
                    📄 仅导出下载
                </button>
                <button onclick="doExportWord(true)" 
                    class="w-full bg-green-500 hover:bg-green-600 text-white font-bold py-3 px-4 rounded-lg transition">
                    💾 导出并保存到数据库
                </button>
                <button onclick="closeExportOption()" 
                    class="w-full border border-gray-300 text-gray-700 font-bold py-3 px-4 rounded-lg hover:bg-gray-100 transition">
                    取消
                </button>
            </div>
        </div>
    </div>
    
    <!-- 导出按钮 -->
    <div class="fixed bottom-6 right-6 flex gap-2">
        <button onclick="openExportOption()" 
            class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-full shadow-lg transition">
            📄 导出Word
        </button>
        <button onclick="exportData()" 
            class="bg-gray-700 hover:bg-gray-800 text-white font-bold py-3 px-6 rounded-full shadow-lg transition">
            📤 导出数据
        </button>
    </div>

    <script>
        let logs = JSON.parse(localStorage.getItem('workLogs') || '[]');
        let currentLogId = null;
        let pendingExportSingle = false;
        
        // IndexedDB
        let db;
        const DB_NAME = 'WorkLogDocsDB';
        const DB_VERSION = 1;
        const STORE_NAME = 'documents';
        
        function initDB() {
            return new Promise((resolve, reject) => {
                const request = indexedDB.open(DB_NAME, DB_VERSION);
                request.onerror = () => reject(request.error);
                request.onsuccess = () => { db = request.result; resolve(db); };
                request.onupgradeneeded = (event) => {
                    const database = event.target.result;
                    if (!database.objectStoreNames.contains(STORE_NAME)) {
                        database.createObjectStore(STORE_NAME, { keyPath: 'id' });
                    }
                };
            });
        }
        
        async function saveDocToDB(docData) {
            return new Promise((resolve, reject) => {
                const transaction = db.transaction([STORE_NAME], 'readwrite');
                const store = transaction.objectStore(STORE_NAME);
                const request = store.put(docData);
                request.onsuccess = () => resolve();
                request.onerror = () => reject(request.error);
            });
        }
        
        async function getAllDocs() {
            return new Promise((resolve, reject) => {
                const transaction = db.transaction([STORE_NAME], 'readonly');
                const store = transaction.objectStore(STORE_NAME);
                const request = store.getAll();
                request.onsuccess = () => resolve(request.result);
                request.onerror = () => reject(request.error);
            });
        }
        
        async function deleteDocFromDB(id) {
            return new Promise((resolve, reject) => {
                const transaction = db.transaction([STORE_NAME], 'readwrite');
                const store = transaction.objectStore(STORE_NAME);
                const request = store.delete(id);
                request.onsuccess = () => resolve();
                request.onerror = () => reject(request.error);
            });
        }
        
        document.addEventListener('DOMContentLoaded', async () => {
            await initDB();
            renderLogList();
            document.getElementById('searchInput').addEventListener('input', (e) => renderLogList(e.target.value));
            document.getElementById('logDate').valueAsDate = new Date();
            document.getElementById('logTime').value = new Date().toTimeString().slice(0, 5);
        });
        
        function renderLogList(searchTerm = '') {
            const listEl = document.getElementById('logList');
            let filteredLogs = logs;
            if (searchTerm) {
                const term = searchTerm.toLowerCase();
                filteredLogs = logs.filter(log => 
                    (log.content && log.content.toLowerCase().includes(term)) ||
                    (log.spareParts && log.spareParts.toLowerCase().includes(term)) ||
                    (log.tools && log.tools.toLowerCase().includes(term))
                );
            }
            filteredLogs.sort((a, b) => new Date(b.date + ' ' + b.time) - new Date(a.date + ' ' + a.time));
            
            if (filteredLogs.length === 0) {
                listEl.innerHTML = '<div class="p-4 text-center text-gray-400"><p class="text-4xl mb-2">📭</p><p>暂无工作日志</p></div>';
                return;
            }
            
            listEl.innerHTML = filteredLogs.map(log => `
                <div onclick="selectLog('${log.id}')" 
                    class="p-3 border-b border-gray-100 cursor-pointer hover:bg-blue-50 transition ${currentLogId === log.id ? 'bg-blue-100 border-l-4 border-l-blue-500' : ''}">
                    <div class="font-bold text-gray-800">${log.date}</div>
                    <div class="text-sm text-gray-500">${log.time}</div>
                    <div class="text-sm text-gray-600 mt-1 truncate">${log.content || '无工作内容'}</div>
                    ${log.images && log.images.length > 0 ? `<div class="text-xs text-purple-500 mt-1">📷 ${log.images.length}张图片</div>` : ''}
                </div>
            `).join('');
        }
        
        function createNewLog() {
            currentLogId = null;
            clearForm();
            document.getElementById('noSelection').classList.add('hidden');
            document.getElementById('logForm').classList.remove('hidden');
            document.getElementById('formTitle').textContent = '新增工作日志';
            document.getElementById('deleteBtn').classList.add('hidden');
            document.getElementById('exportCurrentBtn').classList.add('hidden');
            document.getElementById('lastUpdated').classList.add('hidden');
            document.getElementById('logDate').valueAsDate = new Date();
            document.getElementById('logTime').value = new Date().toTimeString().slice(0, 5);
            renderLogList();
        }
        
        function selectLog(id) {
            const log = logs.find(l => l.id === id);
            if (!log) return;
            currentLogId = id;
            document.getElementById('noSelection').classList.add('hidden');
            document.getElementById('logForm').classList.remove('hidden');
            document.getElementById('formTitle').textContent = '编辑工作日志';
            document.getElementById('deleteBtn').classList.remove('hidden');
            document.getElementById('exportCurrentBtn').classList.remove('hidden');
            document.getElementById('lastUpdated').classList.remove('hidden');
            document.getElementById('logDate').value = log.date;
            document.getElementById('logTime').value = log.time;
            document.getElementById('logContent').value = log.content || '';
            document.getElementById('logSpareParts').value = log.spareParts || '';
            document.getElementById('logTools').value = log.tools || '';
            document.getElementById('logPrecautions').value = log.precautions || '';
            document.getElementById('logSteps').value = log.steps || '';
            document.getElementById('updatedTime').textContent = log.updatedAt || log.createdAt;
            renderImagePreviews(log.images || []);
            renderLogList();
        }
        
        function clearForm() {
            document.getElementById('logContent').value = '';
            document.getElementById('logSpareParts').value = '';
            document.getElementById('logTools').value = '';
            document.getElementById('logPrecautions').value = '';
            document.getElementById('logSteps').value = '';
            document.getElementById('imagePreview').innerHTML = '';
        }
        
        function saveLog() {
            const date = document.getElementById('logDate').value;
            const time = document.getElementById('logTime').value;
            if (!date || !time) { alert('请填写日期和时间'); return; }
            
            const logData = {
                date, time,
                content: document.getElementById('logContent').value.trim(),
                spareParts: document.getElementById('logSpareParts').value.trim(),
                tools: document.getElementById('logTools').value.trim(),
                precautions: document.getElementById('logPrecautions').value.trim(),
                steps: document.getElementById('logSteps').value.trim(),
                images: getCurrentImages()
            };
            const now = new Date().toLocaleString('zh-CN');
            
            if (currentLogId) {
                const index = logs.findIndex(l => l.id === currentLogId);
                if (index !== -1) logs[index] = { ...logs[index], ...logData, updatedAt: now };
            } else {
                logs.push({ id: 'log_' + Date.now(), ...logData, createdAt: now, updatedAt: now });
            }
            saveToStorage();
            renderLogList();
            showToast('💾 保存成功！');
        }
        
        function deleteLog() { document.getElementById('deleteModal').classList.remove('hidden'); }
        function closeDeleteModal() { document.getElementById('deleteModal').classList.add('hidden'); }
        
        function confirmDelete() {
            if (currentLogId) {
                logs = logs.filter(l => l.id !== currentLogId);
                saveToStorage();
                currentLogId = null;
                document.getElementById('noSelection').classList.remove('hidden');
                document.getElementById('logForm').classList.add('hidden');
                renderLogList();
            }
            closeDeleteModal();
            showToast('🗑️ 删除成功！');
        }
        
        let tempImages = [];
        
        function handleImageUpload(event) {
            const files = event.target.files;
            for (let file of files) {
                const reader = new FileReader();
                reader.onload = (e) => {
                    const imgData = { id: 'img_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9), data: e.target.result };
                    if (currentLogId) {
                        const log = logs.find(l => l.id === currentLogId);
                        if (log) { if (!log.images) log.images = []; log.images.push(imgData); saveToStorage(); renderImagePreviews(log.images); }
                    } else { tempImages.push(imgData); renderImagePreviews(tempImages); }
                };
                reader.readAsDataURL(file);
            }
            event.target.value = '';
        }
        
        function renderImagePreviews(images) {
            const previewEl = document.getElementById('imagePreview');
            if (!images || images.length === 0) { previewEl.innerHTML = '<p class="text-sm text-gray-400">暂无图片</p>'; return; }
            previewEl.innerHTML = images.map(img => `
                <div class="relative group">
                    <img src="${img.data}" class="image-preview">
                    <button onclick="removeImage('${img.id}')" class="absolute -top-2 -right-2 bg-red-500 text-white rounded-full w-6 h-6 flex items-center justify-center opacity-0 group-hover:opacity-100 transition">×</button>
                </div>
            `).join('');
        }
        
        function getCurrentImages() {
            if (currentLogId) { const log = logs.find(l => l.id === currentLogId); return log ? (log.images || []) : []; }
            return tempImages;
        }
        
        function removeImage(imgId) {
            if (currentLogId) {
                const log = logs.find(l => l.id === currentLogId);
                if (log && log.images) { log.images = log.images.filter(img => img.id !== imgId); saveToStorage(); renderImagePreviews(log.images); }
            } else { tempImages = tempImages.filter(img => img.id !== imgId); renderImagePreviews(tempImages); }
        }
        
        function saveToStorage() { localStorage.setItem('workLogs', JSON.stringify(logs)); }
        
        function exportData() {
            const dataStr = JSON.stringify(logs, null, 2);
            const blob = new Blob([dataStr], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a'); a.href = url;
            a.download = `工作日志_${new Date().toLocaleDateString('zh-CN').replace(/\//g, '-')}.json`;
            document.body.appendChild(a); a.click(); document.body.removeChild(a); URL.revokeObjectURL(url);
            showToast('📤 导出成功！');
        }
        
        function openExportOption() {
            if (logs.length === 0) { alert('暂无日志可导出'); return; }
            document.getElementById('exportOptionModal').classList.remove('hidden');
            pendingExportSingle = false;
        }
        
        function closeExportOption() { document.getElementById('exportOptionModal').classList.add('hidden'); }
        
        async function doExportWord(saveToDatabase = false) {
            closeExportOption();
            let targetLogs = logs;
            const isSingle = pendingExportSingle && currentLogId;
            if (isSingle) targetLogs = logs.filter(l => l.id === currentLogId);
            if (targetLogs.length === 0) { alert('无可导出的日志'); return; }
            
            let htmlContent = `<html><head><meta charset="utf-8"><style>
                body { font-family: '宋体', serif; font-size: 14px; }
                h1 { text-align: center; font-size: 24px; margin-bottom: 20px; }
                .log-entry { border: 1px solid #000; padding: 15px; margin-bottom: 20px; page-break-inside: avoid; }
                table { width: 100%; border-collapse: collapse; margin: 10px 0; }
                td { border: 1px solid #000; padding: 8px; vertical-align: top; }
                .label { background: #e0e0e0; font-weight: bold; width: 80px; }
                img { max-width: 300px; max-height: 200px; margin: 5px; }
            </style></head><body><h1>日常工作日志</h1>`;
            
            const sortedLogs = [...targetLogs].sort((a, b) => new Date(b.date + ' ' + b.time) - new Date(a.date + ' ' + a.time));
            
            sortedLogs.forEach(log => {
                htmlContent += `<div class="log-entry">
                    <table>
                        <tr><td class="label">日期</td><td>${log.date}</td></tr>
                        <tr><td class="label">时间</td><td>${log.time}</td></tr>
                        <tr><td class="label">工作内容</td><td>${log.content || '无'}</td></tr>
                        <tr><td class="label">备件</td><td>${log.spareParts || '无'}</td></tr>
                        <tr><td class="label">工具</td><td>${log.tools || '无'}</td></tr>
                        <tr><td class="label">注意事项</td><td>${log.precautions || '无'}</td></tr>
                        <tr><td class="label">工作步骤</td><td>${log.steps || '无'}</td></tr>`;
                if (log.images && log.images.length > 0) {
                    htmlContent += `<tr><td class="label">工作图片</td><td>`;
                    log.images.forEach(img => { htmlContent += `<img src="${img.data}" />`; });
                    htmlContent += `</td></tr>`;
                }
                htmlContent += `</table></div>`;
            });
            htmlContent += `</body></html>`;
            
            const doc = htmlDocx.asBlob(htmlContent);
            const now = new Date().toLocaleString('zh-CN');
            const filename = isSingle 
                ? `工作日志_${sortedLogs[0].date}_${sortedLogs[0].time.replace(':', '-')}.doc`
                : `工作日志_${new Date().toLocaleDateString('zh-CN').replace(/\//g, '-')}.doc`;
            
            if (saveToDatabase) {
                const reader = new FileReader();
                reader.onload = async (e) => {
                    // 收集所有日志内容用于搜索
                    const allContent = sortedLogs.map(l => `${l.content || ''} ${l.spareParts || ''} ${l.tools || ''} ${l.precautions || ''} ${l.steps || ''}`).join(' ');
                    const docData = {
                        id: 'doc_' + Date.now(),
                        filename: filename,
                        data: e.target.result,
                        logIds: isSingle ? [currentLogId] : logs.map(l => l.id),
                        logCount: sortedLogs.length,
                        createdAt: now,
                        dateRange: isSingle ? `${sortedLogs[0].date}` : `${sortedLogs[sortedLogs.length-1].date} ~ ${sortedLogs[0].date}`,
                        searchContent: allContent // 用于搜索
                    };
                    try { await saveDocToDB(docData); showToast('💾 已保存到数据库！'); } catch (err) { console.error(err); alert('保存失败'); }
                };
                reader.readAsDataURL(doc);
            }
            
            const url = URL.createObjectURL(doc);
            const a = document.createElement('a'); a.href = url; a.download = filename;
            document.body.appendChild(a); a.click(); document.body.removeChild(a); URL.revokeObjectURL(url);
            showToast('📄 Word导出成功！');
        }
        
        function exportCurrentToWord() {
            if (!currentLogId) return;
            pendingExportSingle = true;
            document.getElementById('exportOptionModal').classList.remove('hidden');
        }
        
        async function openDocManager() {
            document.getElementById('docManagerModal').classList.remove('hidden');
            document.getElementById('docSearchInput').value = '';
            await renderDocList();
        }
        function closeDocManager() { document.getElementById('docManagerModal').classList.add('hidden'); }
        
        async function renderDocList(searchTerm = '') {
            const docs = await getAllDocs();
            const docListEl = document.getElementById('docList');
            
            // 过滤文档
            let filteredDocs = docs;
            if (searchTerm) {
                const term = searchTerm.toLowerCase();
                filteredDocs = docs.filter(doc => 
                    doc.filename.toLowerCase().includes(term) ||
                    (doc.searchContent && doc.searchContent.toLowerCase().includes(term)) ||
                    doc.dateRange.toLowerCase().includes(term)
                );
            }
            
            document.getElementById('docCount').textContent = filteredDocs.length;
            
            if (filteredDocs.length === 0) { 
                docListEl.innerHTML = `<div class="text-center text-gray-400 py-8">📭 ${searchTerm ? '没有找到匹配的文档' : '暂无导出的文档'}</div>`; 
                return; 
            }
            
            filteredDocs.sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt));
            
            docListEl.innerHTML = filteredDocs.map(doc => `
                <div class="doc-item p-3 border border-gray-200 rounded-lg mb-2 flex items-center justify-between">
                    <div class="flex items-center gap-3">
                        <span class="text-3xl">📄</span>
                        <div>
                            <div class="font-bold text-gray-800">${doc.filename}</div>
                            <div class="text-sm text-gray-500">${doc.logCount}条日志 | ${doc.dateRange}</div>
                            <div class="text-xs text-gray-400">保存时间: ${doc.createdAt}</div>
                            ${searchTerm && doc.searchContent ? `<div class="text-xs text-purple-600 mt-1 truncate">内容包含: "${searchTerm}"</div>` : ''}
                        </div>
                    </div>
                    <div class="flex gap-2">
                        <button onclick="downloadDoc('${doc.id}')" class="bg-blue-500 hover:bg-blue-600 text-white py-1 px-3 rounded text-sm">⬇️ 下载</button>
                        <button onclick="deleteDoc('${doc.id}')" class="bg-red-500 hover:bg-red-600 text-white py-1 px-3 rounded text-sm">🗑️</button>
                    </div>
                </div>
            `).join('');
        }
        
        function downloadDoc(docId) {
            getAllDocs().then(docs => {
                const doc = docs.find(d => d.id === docId);
                if (!doc) return;
                const byteCharacters = atob(doc.data.split(',')[1]);
                const byteNumbers = new Array(byteCharacters.length);
                for (let i = 0; i < byteCharacters.length; i++) byteNumbers[i] = byteCharacters.charCodeAt(i);
                const byteArray = new Uint8Array(byteNumbers);
                const blob = new Blob([byteArray], { type: 'application/msword' });
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a'); a.href = url; a.download = doc.filename;
                document.body.appendChild(a); a.click(); document.body.removeChild(a); URL.revokeObjectURL(url);
                showToast('⬇️ 下载成功！');
            });
        }
        
        async function deleteDoc(docId) {
            if (!confirm('确定要删除这个文档吗？')) return;
            await deleteDocFromDB(docId);
            await renderDocList();
            showToast('🗑️ 删除成功！');
        }
        
        function showToast(message) {
            const toast = document.createElement('div');
            toast.className = 'fixed top-4 right-4 bg-green-500 text-white px-6 py-3 rounded-lg shadow-lg z-50 animate-pulse';
            toast.textContent = message;
            document.body.appendChild(toast);
            setTimeout(() => { toast.remove(); }, 2000);
        }
    </script>
</body>
</html>
